# ═══ BSCCL NetWatch Configuration ═══
# Copy to .env and fill in real values

# ── Network Access (choose ONE) ──
MONITOR_HOST=192.168.200.230
# MONITOR_HOST=103.16.152.8  # Uncomment for home/remote access

# ── Syslog Input ──
SYSLOG_MODE=loki_ws
SYSLOG_UDP_PORT=1514

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///bsccl_netwatch.db

# ── Web Server ──
WEB_HOST=0.0.0.0
WEB_PORT=8080

# ── Discord Webhook ──
DISCORD_WEBHOOK_URL=
DISCORD_ENABLED=false

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# ── Grafana (read-only API key) ──
GRAFANA_API_KEY=
GRAFANA_DASHBOARD_UID=8sWAY1LMz

# ── Notification Dedup ──
DEDUP_WINDOW_SECONDS=300
BGP_FLAP_WINDOW_SECONDS=120
BUNDLE_GROUP_WINDOW_SECONDS=30
