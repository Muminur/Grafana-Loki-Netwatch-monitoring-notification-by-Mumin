# ═══ BSCCL NetWatch Configuration ═══
# Copy to .env and fill in real values

# ── Network Access (choose ONE) ──
MONITOR_HOST=192.168.200.230
# MONITOR_HOST=103.16.152.8  # Uncomment for home/remote access

# ── Syslog Input ──
SYSLOG_MODE=loki_ws
SYSLOG_UDP_PORT=1514

# ── Database ──
# Local development (relative to project root):
DATABASE_URL=sqlite+aiosqlite:///bsccl_netwatch.db
# Docker (must match the volume mount at /app/data):
# DATABASE_URL=sqlite+aiosqlite:////app/data/bsccl_netwatch.db
RETENTION_DAYS=90

# ── Web Server ──
WEB_HOST=0.0.0.0
WEB_PORT=8080

# ── Discord Webhook ──
DISCORD_WEBHOOK_URL=
DISCORD_ENABLED=false

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# ── Grafana (read-only API key) ──
GRAFANA_API_KEY=
GRAFANA_DASHBOARD_UID=8sWAY1LMz

# ── Notification Dedup ──
DEDUP_WINDOW_SECONDS=300
BGP_FLAP_WINDOW_SECONDS=120
BUNDLE_GROUP_WINDOW_SECONDS=30

# ── ASN Lookup (BigDataCloud) ──
ASN_API_KEY=

# ── API Authentication (optional) ──
# Empty = disabled (all endpoints open — backward-compatible default).
# Set a value to require the X-API-Key header on mutating endpoints
# (POST /api/maintenance, DELETE /api/maintenance/{id},
#  POST /api/settings/hardware-noise, POST /api/incidents/{id}/acknowledge).
API_KEY=

# ── Logging ──
# LOG_FORMAT: "text" (default, human-readable) or "json" (structured/NDJSON).
# LOG_LEVEL: standard level name (DEBUG/INFO/WARNING/ERROR).
# WARNING: DEBUG level logs raw syslog content including device IPs,
# BGP neighbor addresses, and network topology details.
LOG_FORMAT=text
LOG_LEVEL=INFO

# ── CORS (comma-separated allowed origins) ──
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
